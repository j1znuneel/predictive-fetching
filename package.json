{
  "name": "prefetch-ai",
  "version": "0.1.0",
  "description": "Predictive prefetching for React using mouse kinematics and Markov chains",
  "source": "src/index.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.module.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.module.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "microbundle --jsx React.createElement --jsxFragment React.Fragment",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "microbundle": "^0.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.1",
    "vitest": "^4.1.7"
  }
}
